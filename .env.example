# Docker Compose template. Copy to .env for local Docker runs.

# Compose ports
BACKEND_PORT=8080
SOCKET_PORT=9092
CLIENT_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
PGADMIN_PORT=5050

# PostgreSQL container
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ticket_booking_db

# Application
APPLICATION_NAME=mini-concert-booking-app
APPLICATION_VERSION=0.0.1

# Super admin bootstrap
SUPER_USER_USERNAME=admin
SUPER_USER_PASSWORD=change-me
SUPER_USER_EMAIL=admin@example.com
SUPER_USER_FULL_NAME=System Admin

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# Backend runtime tuning
THREAD_POOL_CORE_SIZE=5
THREAD_POOL_MAX_SIZE=10
THREAD_POOL_QUEUE_CAPACITY=25
TOMCAT_MAX_THREADS=50
TOMCAT_MIN_SPARE_THREADS=10
TOMCAT_MAX_QUEUE_CAPACITY=100

# Redis
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=
SPRING_REDIS_TIMEOUT=2s

# Bank transfer checkout
BANK_ACCOUNT_NUMBER=0000000000
BANK_ACCOUNT_NAME=MINI CONCERT BOOKING

# VNPay sandbox checkout
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/customer/booking/vnpay-return
VNPAY_IPN_URL=http://localhost:8080/api/v1/customer/payments/vnpay/ipn

# VietQR + SePay checkout
VIETQR_BANK_ID=ICB
VIETQR_ACCOUNT_NO=
VIETQR_ACCOUNT_NAME=
VIETQR_TEMPLATE=compact2
SEPAY_API_KEY=

# Mail
MAIL_USERNAME=
MAIL_PASSWORD=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:9092
NEXT_PUBLIC_ENABLE_DEV_PAYMENT=true
SOCKET_ORIGIN=http://localhost:3000

# Tools
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me
